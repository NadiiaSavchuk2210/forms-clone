{
  "name": "server",
  "version": "1.0.0",
  "private": true,
  "description": "GraphQL API server for forms clone",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node -r tsconfig-paths/register src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server/src/index.js",
    "type-check": "tsc -p tsconfig.json --noEmit",
    "test": "node -r ts-node/register -r tsconfig-paths/register --test src/resolvers.test.ts"
  },
  "type": "commonjs",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/uuid": "^10.0.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@apollo/server": "^5.0.0",
    "graphql": "^16.11.0",
    "uuid": "^9.0.1"
  }
}
